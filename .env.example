PORT=5000
BACKEND_URL=https://ukmkemasan-erp-backend-production.up.railway.app
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=2h
NODE_ENV=production

# Cloudinary
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Midtrans
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=true

# Frontend
FRONTEND_URL=https://ukmkemasan-erp-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,https://ukmkemasan-erp-frontend.vercel.app,https://ukmkemasan-erp-backend-production.up.railway.app
MIDTRANS_FINISH_URL=https://ukmkemasan-erp-frontend.vercel.app/portal
MIDTRANS_PENDING_URL=https://ukmkemasan-erp-frontend.vercel.app/portal
MIDTRANS_ERROR_URL=https://ukmkemasan-erp-frontend.vercel.app/portal
